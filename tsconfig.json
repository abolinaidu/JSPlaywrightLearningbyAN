{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
     "lib": ["esnext", "dom"],
     "types": ["node"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "experimentalDecorators": true
  },
  "exclude": ["node_modules"]
}
//"lib": ["ES2020"],